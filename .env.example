# ══════════════════════════════════════════════════════════════
#  JobPulse AI — Environment Configuration
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── API Keys (required) ──────────────────────────────────────
# Get a free Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get an Apify token: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# ── Platform Configuration ───────────────────────────────────
# Which platforms to scrape: "both", "linkedin", or "naukri"
PLATFORMS=both

# Search keywords (comma-separated) — what jobs to search for
# If not set, defaults to Node.js/MERN/Full Stack searches
# Examples:
#   SEARCH_KEYWORDS=Python Developer, Django Developer, Data Engineer
#   SEARCH_KEYWORDS=Java Spring Boot, Microservices Java
#   SEARCH_KEYWORDS=React Developer, Frontend Engineer, UI Developer
SEARCH_KEYWORDS=

# Search location (default: India)
SEARCH_LOCATION=India

# ── AI Analysis ──────────────────────────────────────────────
# Set to "true" for Gemini AI scoring, "false" for keyword-based scoring
AI_ANALYSIS=true

# Batch mode: send ALL jobs in 1 API call (avoids rate limits)
# Set to "false" to analyze each job individually (uses more API calls)
BATCH_AI=true

# Max number of jobs to analyze with AI (default: 20)
JOB_COUNT=20

# ── User Info (optional) ─────────────────────────────────────
# Your name (shown in email subject and Excel reports)
USER_NAME=

# ── Email Settings ───────────────────────────────────────────
# Gmail address to send reports FROM
GMAIL_USER=your-email@gmail.com

# Email address to receive reports (defaults to GMAIL_USER if not set)
RECIPIENT_EMAIL=your-email@gmail.com

# ── Google OAuth2 (run setup_google_auth.py to get these) ────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=1//your_refresh_token

# ── Google Drive (optional) ──────────────────────────────────
# Custom root folder ID in Google Drive (auto-created if empty)
DRIVE_FOLDER_ID=
